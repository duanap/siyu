NODE_ENV=development

# PostgreSQL 17+ and Redis 7.4+/Valkey may run locally or be provided by a cloud service.
DATABASE_URL=postgresql://siyu:siyu_local_only@127.0.0.1:5432/siyu?schema=public
REDIS_URL=redis://127.0.0.1:6379

JWT_SECRET=siyu-native-local-jwt-secret-change-me
SIYU_API_PORT=3000
SIYU_API_ORIGIN=http://127.0.0.1:3000
SIYU_CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:8080
SIYU_PUBLIC_URL=http://localhost:5173
SIYU_ADMIN_URL=http://localhost:5174/admin/
SIYU_COOKIE_SECURE=false

SIYU_GATEWAY_HOST=127.0.0.1
SIYU_GATEWAY_PORT=8080

SIYU_QQ_CLIENT_ID=
SIYU_QQ_CLIENT_SECRET=
SIYU_QQ_CALLBACK_URL=http://localhost:3000/api/v1/auth/qq/callback

# test writes password-reset mail to Redis; no production provider exists yet.
SIYU_MAIL_PROVIDER=test

# Recurring Worker scheduling, paging, concurrency, retries, and exponential backoff base delay.
SIYU_RECURRING_SCAN_INTERVAL_MS=60000
SIYU_RECURRING_SCAN_BATCH_SIZE=200
SIYU_RECURRING_WORKER_CONCURRENCY=8
SIYU_RECURRING_JOB_ATTEMPTS=5
SIYU_RECURRING_BACKOFF_DELAY_MS=1000
